<Window
    x:Class="IMV.Views.ImageWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Image Viewer"
    Width="1200"
    Height="800">

    <Grid>
        <Grid.RowDefinitions>
            <!--  ヘッダー  -->
            <RowDefinition Height="38" />
            <!--  本体  -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  上部情報バー  -->
        <Border
            Grid.Row="0"
            Padding="0"
            Background="#222">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  モード切替ボタン  -->
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">

                    <Button
                        x:Name="Mode1Button"
                        Width="32"
                        Height="32"
                        Margin="0,0,5,0"
                        Click="Mode1Button_Click"
                        Content="1" />

                    <Button
                        x:Name="Mode2RLButton"
                        Width="32"
                        Height="32"
                        Margin="0,0,5,0"
                        Click="Mode2RLButton_Click"
                        Content="2RL" />

                    <Button
                        x:Name="Mode2LRButton"
                        Width="32"
                        Height="32"
                        Margin="0,0,5,0"
                        Click="Mode2LRButton_Click"
                        Content="2LR" />
                </StackPanel>

                <!--  タイトル  -->
                <TextBlock
                    x:Name="IndexText"
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="White" />
            </Grid>
        </Border>

        <!--  画像表示  -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftCol" Width="*" />
                <ColumnDefinition x:Name="RightCol" Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                BorderBrush="Gray"
                BorderThickness="1">
                <Image
                    x:Name="LeftImage"
                    MouseRightButtonUp="Image_MouseRightButtonUp"
                    RenderOptions.BitmapScalingMode="Fant"
                    Stretch="Uniform" />
            </Border>

            <Border
                Grid.Column="2"
                BorderBrush="Gray"
                BorderThickness="1">
                <Image
                    x:Name="RightImage"
                    MouseRightButtonUp="Image_MouseRightButtonUp"
                    RenderOptions.BitmapScalingMode="Fant"
                    Stretch="Uniform" />
            </Border>
        </Grid>
    </Grid>
</Window>